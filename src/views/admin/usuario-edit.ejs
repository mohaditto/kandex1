<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Editar Usuario</h1>
    <a href="/admin/usuarios" class="btn btn-secondary">Volver</a>
</div>

<% if (alert) { %>
    <div class="alert alert-<%= alert.type %> alert-dismissible fade show" role="alert">
        <%= alert.message %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
<% } %>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header bg-light">
                <h2 class="h5 mb-0">Información del Usuario</h2>
            </div>
            <div class="card-body">
                <form action="/admin/usuarios/<%= usuario.id %>/edit" method="POST">
                    <div class="mb-3">
                        <label for="nombre_usuario" class="form-label">Nombre de Usuario</label>
                        <input type="text" class="form-control" id="nombre_usuario" name="nombre_usuario" value="<%= usuario.nombre_usuario %>" required maxlength="100">
                    </div>
                    <div class="mb-3">
                        <label for="email" class="form-label">Email</label>
                        <input type="email" class="form-control" id="email" name="email" value="<%= usuario.email %>" required maxlength="100">
                    </div>
                    <div class="mb-3">
                        <label for="rol" class="form-label">Rol</label>
                        <select class="form-select" id="rol" name="rol" required>
                            <option value="">-- Seleccionar rol --</option>
                            <% roles.forEach(rol => { %>
                                <option value="<%= rol %>" <%= usuario.rol === rol ? 'selected' : '' %>><%= rol %></option>
                            <% }); %>
                        </select>
                        <small class="form-text text-muted">
                            • <strong>Administrador:</strong> Acceso total al sistema<br>
                            • <strong>Líder:</strong> Gestiona su equipo y tareas<br>
                            • <strong>Miembro:</strong> Usuario regular
                        </small>
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg w-100">
                        <i class="fas fa-save"></i> Guardar Cambios
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card">
            <div class="card-header bg-light">
                <h2 class="h5 mb-0">Equipos del Usuario</h2>
            </div>
            <div class="card-body">
                <% if (equipos.length === 0) { %>
                    <div class="alert alert-info mb-0">
                        <i class="fas fa-info-circle"></i> No hay equipos disponibles en el sistema.
                    </div>
                <% } else { %>
                    <!-- FORMULARIO PARA AGREGAR EQUIPO -->
                    <form action="/admin/usuarios/<%= usuario.id %>/equipos" method="POST" class="mb-4">
                        <div class="mb-3">
                            <label for="equipo_id" class="form-label fw-bold">Agregar a un equipo:</label>
                            <div class="input-group">
                                <select class="form-select" id="equipo_id" name="equipo_id">
                                    <option value="">-- Seleccionar equipo --</option>
                                    <% equipos.forEach(equipo => { %>
                                        <% if (!equiposUsuarioIds.has(equipo.id)) { %>
                                            <option value="<%= equipo.id %>"><%= equipo.nombre_equipo %></option>
                                        <% } %>
                                    <% }); %>
                                </select>
                                <button type="submit" class="btn btn-success btn-lg" id="btn-agregar-equipo">
                                    <i class="fas fa-plus"></i> Agregar
                                </button>
                            </div>
                            <% 
                                const equiposNoAsignados = equipos.filter(e => !equiposUsuarioIds.has(e.id));
                                if (equiposNoAsignados.length === 0) {
                            %>
                                <small class="form-text text-muted d-block mt-2">
                                    ✓ El usuario ya está en todos los equipos disponibles
                                </small>
                            <% } %>
                        </div>
                    </form>

                    <!-- LISTA DE EQUIPOS ACTUALES -->
                    <% if (equiposUsuario.length === 0) { %>
                        <div class="alert alert-warning mb-0">
                            <i class="fas fa-exclamation-triangle"></i> El usuario no pertenece a ningún equipo.
                        </div>
                    <% } else { %>
                        <h6 class="mb-3 fw-bold">Equipos actuales:</h6>
                        <div class="list-group">
                            <% equiposUsuario.forEach(equipo => { %>
                                <div class="list-group-item d-flex justify-content-between align-items-start">
                                    <div class="flex-grow-1">
                                        <div class="fw-bold"><%= equipo.nombre_equipo %></div>
                                        <small class="text-muted"><%= equipo.descripcion || 'Sin descripción' %></small>
                                    </div>
                                    <form action="/admin/usuarios/<%= usuario.id %>/equipos/<%= equipo.id %>/delete" method="POST" class="ms-2">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Quitar del equipo">
                                            <i class="fas fa-trash"></i> Quitar
                                        </button>
                                    </form>
                                </div>
                            <% }); %>
                        </div>
                    <% } %>
                <% } %>
            </div>
        </div>
    </div>
</div>
</div>
