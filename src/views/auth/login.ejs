<div class="login-page">
    <div class="login-panel">
        <div class="login-brand text-center mb-4">
            <div class="login-logo">K</div>
            <h1 class="h3 mb-2">Bienvenido a Kandex</h1>
            <p class="text-muted mb-0">Organiza tus tareas y equipos con un panel claro y centralizado.</p>
        </div>

        <div class="card login-card shadow-lg border-0">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <h2 class="h4 mb-1">Iniciar Sesión</h2>
                    <p class="text-muted mb-0">Accede a tu tablero y comienza a gestionar tu trabajo.</p>
                </div>
                <% if (typeof alert !== 'undefined' && alert) { %>
                    <div class="alert alert-<%= alert.type %>" role="alert"><%= alert.message %></div>
                <% } %>

                <form action="/auth/login" method="POST">
                    <div class="mb-3">
                        <label for="email" class="form-label">Email</label>
                        <input type="email" class="form-control form-control-lg" id="email" name="email" required maxlength="100" placeholder="tu@email.com" value="<%= typeof form !== 'undefined' ? (form.email || '') : '' %>">
                    </div>
                    <div class="mb-4">
                        <label for="password" class="form-label">Contraseña</label>
                        <input type="password" class="form-control form-control-lg" id="password" name="password" required placeholder="********">
                    </div>
                    <button type="submit" class="btn btn-primary btn-login w-100 mb-3">Iniciar Sesión</button>
                </form>
            </div>
            <div class="card-footer text-center bg-transparent border-top px-4 py-3">
                <p class="mb-0 text-muted">¿No tienes cuenta? <a href="/auth/register" class="text-primary fw-bold">Regístrate aquí</a></p>
            </div>
        </div>
    </div>
</div>
