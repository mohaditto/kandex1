<div class="login-page">
    <div class="login-panel">
        <div class="login-brand text-center mb-4">
            <div class="logo-box" style="box-shadow:0 12px 32px rgba(16,185,129,.4);background:linear-gradient(135deg,#059669,#10b981);">
                <i class="bi bi-person-plus-fill"></i></div>
            <h1 class="h3 mb-2">Crear Cuenta</h1>
            <p>¡Únete a Kandex y organiza tus tareas hoy!</p>
        </div>

        <div class="card lcard shadow-lg border-0">
            <div class="card-body p-4">
                <% if (alert) { %>
                    <div class="alert alert-<%= alert.type %>" role="alert"><%= alert.message %></div>
                <% } %>
                <form action="/auth/register" method="POST">
                    <div class="mb-3">
                        <label for="nombre_usuario" class="form-label">Nombre de Usuario</label>
                        <input type="text" class="form-control form-control-lg" id="nombre_usuario" name="nombre_usuario" required maxlength="100" placeholder="Tu nombre" value="<%= form.nombre_usuario || '' %>">
                    </div>
                    <div class="mb-3">
                        <label for="email" class="form-label">Email</label>
                        <input type="email" class="form-control form-control-lg" id="email" name="email" required maxlength="100" placeholder="tu@email.com" value="<%= form.email || '' %>">
                    </div>
                    <div class="mb-4">
                        <label for="password" class="form-label">Contraseña</label>
                        <input type="password" class="form-control form-control-lg" id="password" name="password" required minlength="8" placeholder="********">
                    </div>
                    <button type="submit" class="btn-login" style="background:linear-gradient(135deg,#059669,#10b981);">
                        <i class="bi bi-person-check me-2"></i>Registrate
                    </button>
                </form>
            </div>
            <div class="card-footer text-center bg-transparent border-top px-4 py-3">
                <p class="mb-0 text-muted">¿Ya tienes cuenta? <a href="/auth/login" class="text-ref fw-bold">Inicia sesión</a></p>
            </div>
        </div>
    </div>
</div>