<div class="hero-section mb-5">
    <h1>Bienvenido a Kandex</h1>
    <p>Organiza tus tareas de manera eficiente con nuestro tablero Kanban</p>
    <a href="/tareas" class="btn btn-light btn-hero"><i class="bi bi-kanban me-1"></i>Ver Mi Tablero</a>
</div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="scard">
            <i class="bi bi-check-circle-fill fs-2 mb-2 d-block"></i>
            <h2><%= tareas.filter(t => t.estado === 'Realizado').length %></h2>
            <p>Tareas Completadas</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="scard">
            <i class="bi bi-arrow-repeat fs-2 mb-2 d-block"></i>
            <h2><%= tareas.filter(t => t.estado === 'En proceso').length %></h2>
            <p>En Proceso</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="scard">
            <i class="bi bi-list-task fs-2 mb-2 d-block"></i>
            <h2><%= tareas.length %></h2>
            <p>Total de Tareas</p>
        </div>
    </div>
</div>

<h2 style="font-size:1.3rem;font-weight:700;letter-spacing:-.03em;">
<i class="bi bi-grid-3x3-gap me-2" style="color:#6366f1"></i>Resumen del Tablero</h2><br>
<div class="row">
    <% estadosTarea.forEach(estado => { %>
        <div class="col-md-4">
            <div id="<%= estado.id %>" class="kanban-column" data-estado="<%= estado.nombre %>">
                <h3 class="col-lbl"><%= estado.nombre %></h3>
                <% tareas.filter(t => t.estado === estado.nombre).forEach(tarea => { %>
                    <div class="task-card" draggable="true" data-id="<%= tarea.id %>">
                        <h5><%= tarea.titulo %></h5>
                        <p><%= tarea.descripcion %></p>
                        <span class="badge priority-badge priority-<%= tarea.prioridad %>"><%= tarea.prioridad %></span>
                        <div class="mt-2">
                            <a href="/tareas/edit/<%= tarea.id %>" class="btn btn-sm btn-primary me-1"><i class="bi bi-pencil"></i></a>
                            <a href="/tareas/delete/<%= tarea.id %>" class="btn btn-sm btn-danger"><i class="bi bi-trash"></i></a>
                        </div>
                    </div>
                <% }); %>
            </div>
        </div>
    <% }); %>
</div>