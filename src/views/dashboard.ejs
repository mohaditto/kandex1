<div class="hero-section mb-5">
    <h1>Bienvenido a Kandex</h1>
    <p>Organiza tus tareas de manera eficiente con nuestro tablero Kanban</p>
    <a href="/tareas" class="btn btn-primary btn-lg btn-custom">Ver Mis Tareas</a>
</div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="stats-card">
            <h2><%= tareas.filter(t => t.estado === 'Realizado').length %></h2>
            <p>Tareas Completadas</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stats-card">
            <h2><%= tareas.filter(t => t.estado === 'En proceso').length %></h2>
            <p>En Proceso</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stats-card">
            <h2><%= tareas.length %></h2>
            <p>Total de Tareas</p>
        </div>
    </div>
</div>

<h2 class="section-title text-center mb-4">Tu Tablero Kanban</h2>
<div class="row">
    <% estadosTarea.forEach(estado => { %>
        <div class="col-md-4">
            <h3 class="column-title text-center mb-3"><%= estado.nombre %></h3>
            <div id="<%= estado.id %>" class="kanban-column" data-estado="<%= estado.nombre %>">
                <% tareas.filter(t => t.estado === estado.nombre).forEach(tarea => { %>
                    <div class="task-card" draggable="true" data-id="<%= tarea.id %>">
                        <h5><%= tarea.titulo %></h5>
                        <p><%= tarea.descripcion %></p>
                        <span class="badge priority-badge priority-<%= tarea.prioridad %>"><%= tarea.prioridad %></span>
                        <div class="mt-2">
                            <a href="/tareas/edit/<%= tarea.id %>" class="btn btn-sm btn-primary me-1">Editar</a>
                            <a href="/tareas/delete/<%= tarea.id %>" class="btn btn-sm btn-danger">Eliminar</a>
                        </div>
                    </div>
                <% }); %>
            </div>
        </div>
    <% }); %>
</div>
