<h1 class="mb-4">Reportes de Productividad</h1>

<!-- Contenedor de notificaciones -->
<div id="notificaciones" style="position: fixed; top: 20px; right: 20px; z-index: 1050; max-width: 400px;"></div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card bg-primary text-white">
            <div class="card-body">
                <h5 class="card-title">Tareas Completadas</h5>
                <h2><%= completadas.length %></h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-success text-white">
            <div class="card-body">
                <h5 class="card-title">Tiempo Promedio</h5>
                <h2><%= tiempoPromedio %> hrs</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-info text-white">
            <div class="card-body">
                <h5 class="card-title">Total de Tareas</h5>
                <h2><%= tareas.length %></h2>
            </div>
        </div>
    </div>
</div>

<h3 class="mt-4">Filtrar por Rango de Fechas</h3>
<form id="filtroForm" class="row g-3 mb-4">
    <div class="col-md-4">
        <label for="fecha_inicio" class="form-label">Fecha Inicio</label>
        <input type="date" class="form-control" id="fecha_inicio" name="fecha_inicio">
    </div>
    <div class="col-md-4">
        <label for="fecha_fin" class="form-label">Fecha Fin</label>
        <input type="date" class="form-control" id="fecha_fin" name="fecha_fin">
    </div>
    <div class="col-md-4">
        <button type="submit" class="btn btn-primary mt-4">Filtrar</button>
    </div>
</form>

<h3>Tareas Completadas</h3>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Título</th>
            <th>Fecha Creación</th>
            <th>Fecha Finalización</th>
            <th>Tiempo (horas)</th>
        </tr>
    </thead>
    <tbody>
        <% completadas.forEach(tarea => { 
            const inicio = new Date(tarea.fecha_creacion);
            const fin = new Date(tarea.fecha_finalizacion);
            const horas = ((fin - inicio) / (1000 * 60 * 60)).toFixed(2);
        %>
            <tr>
                <td><%= tarea.titulo %></td>
                <td><%= inicio.toLocaleDateString('es-ES') %></td>
                <td><%= fin.toLocaleDateString('es-ES') %></td>
                <td><%= horas %> hrs</td>
            </tr>
        <% }); %>
    </tbody>
</table>

<script>
// Función para mostrar notificaciones
function mostrarNotificacion(mensaje, tipo = 'danger') {
    const container = document.getElementById('notificaciones');
    const alertDiv = document.createElement('div');
    alertDiv.className = `alert alert-${tipo} alert-dismissible fade show`;
    alertDiv.style.marginBottom = '10px';
    alertDiv.innerHTML = `
        ${mensaje}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    `;
    container.appendChild(alertDiv);

    // Auto-descartar después de 5 segundos
    setTimeout(() => {
        alertDiv.remove();
    }, 5000);
}

document.getElementById('filtroForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const inicio = document.getElementById('fecha_inicio').value;
    const fin = document.getElementById('fecha_fin').value;
    
    if (!inicio || !fin) {
        mostrarNotificacion('Por favor completa ambas fechas', 'warning');
        return;
    }

    const response = await fetch(`/reportes/filtrar?fecha_inicio=${inicio}&fecha_fin=${fin}`);
    const data = await response.json();
    mostrarNotificacion(`Se encontraron ${data.total} tareas completadas en ese rango`, 'success');
});
</script>