<h1 class="mb-4">Tablero Kanban</h1>
<a href="/tareas/create" class="btn btn-success mb-3">Nueva Tarea</a>

<!-- Contenedor de notificaciones -->
<div id="notificaciones" style="position: fixed; top: 20px; right: 20px; z-index: 1050; max-width: 400px;"></div>

<div class="row">
    <% estadosTarea.forEach(estado => { %>
        <div class="col-md-4">
            <h3 class="text-center mb-3"><%= estado.nombre %></h3>
            <div id="<%= estado.id %>" class="kanban-column" data-estado="<%= estado.nombre %>">
                <% tareas.filter(t => t.estado === estado.nombre).forEach(tarea => { %>
                    <div class="task-card" draggable="true" data-id="<%= tarea.id %>">
                        <h5><%= tarea.titulo %></h5>
                        <p><%= tarea.descripcion %></p>
                        <small class="text-muted">Prioridad: <%= tarea.prioridad %></small>
                        <div class="mt-2">
                            <a href="/tareas/edit/<%= tarea.id %>" class="btn btn-sm btn-primary">Editar</a>
                            <a href="/tareas/delete/<%= tarea.id %>" class="btn btn-sm btn-danger">Eliminar</a>
                        </div>
                    </div>
                <% }); %>
            </div>
        </div>
    <% }); %>
</div>
