<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h2 class="text-center">Editar Tarea</h2>
            </div>
            <div class="card-body">
                <form action="/tareas/edit/<%= tarea.id %>" method="POST">
                    <div class="mb-3">
                        <label for="titulo" class="form-label">Título</label>
                        <input type="text" class="form-control" id="titulo" name="titulo" value="<%= tarea.titulo %>" required>
                    </div>
                    <div class="mb-3">
                        <label for="descripcion" class="form-label">Descripción</label>
                        <textarea class="form-control" id="descripcion" name="descripcion" rows="4"><%= tarea.descripcion %></textarea>
                    </div>
                    <div class="mb-3">
                        <label for="estado" class="form-label">Estado</label>
                        <select class="form-select" id="estado" name="estado">
                            <option value="Por realizar" <%= tarea.estado === 'Por realizar' ? 'selected' : '' %>>Por realizar</option>
                            <option value="En proceso" <%= tarea.estado === 'En proceso' ? 'selected' : '' %>>En proceso</option>
                            <option value="Realizado" <%= tarea.estado === 'Realizado' ? 'selected' : '' %>>Realizado</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="prioridad" class="form-label">Prioridad</label>
                        <select class="form-select" id="prioridad" name="prioridad">
                            <option value="Baja" <%= tarea.prioridad === 'Baja' ? 'selected' : '' %>>Baja</option>
                            <option value="Media" <%= tarea.prioridad === 'Media' ? 'selected' : '' %>>Media</option>
                            <option value="Alta" <%= tarea.prioridad === 'Alta' ? 'selected' : '' %>>Alta</option>
                            <option value="Urgente" <%= tarea.prioridad === 'Urgente' ? 'selected' : '' %>>Urgente</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="fecha_inicio" class="form-label">Fecha Inicio</label>
                        <input type="date" class="form-control" id="fecha_inicio" name="fecha_inicio" value="<%= tarea.fecha_inicio ? tarea.fecha_inicio.toISOString().split('T')[0] : '' %>">
                    </div>
                    <div class="mb-3">
                        <label for="fecha_limite" class="form-label">Fecha Límite</label>
                        <input type="date" class="form-control" id="fecha_limite" name="fecha_limite" value="<%= tarea.fecha_limite ? tarea.fecha_limite.toISOString().split('T')[0] : '' %>">
                    </div>
                    <button type="submit" class="btn btn-primary">Guardar Cambios</button>
                    <a href="/tareas" class="btn btn-secondary">Cancelar</a>
                </form>
            </div>
        </div>
    </div>
</div>
